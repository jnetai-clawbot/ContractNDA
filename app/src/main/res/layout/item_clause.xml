<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_margin="8dp" app:cardCornerRadius="8dp" app:cardElevation="2dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="12dp">
        <TextView android:id="@+id/clauseTitle" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="16sp" android:textStyle="bold" android:textColor="@color/white" />
        <TextView android:id="@+id/clauseType" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="14sp" android:paddingTop="2dp" />
        <TextView android:id="@+id/clauseRisk" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="13sp" android:paddingTop="2dp" />
        <TextView android:id="@+id/clauseRedFlag" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="13sp" android:textColor="@color/risk_high" android:visibility="gone" />
        <CheckBox android:id="@+id/clauseReviewed" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Reviewed" android:paddingTop="4dp" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>